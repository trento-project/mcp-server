# Environment Configuration Example

# Gemini API Key (required for LLM and embeddings)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# PostgreSQL connection for RAG vector store
# Default for docker-compose setup
PG_URL=postgres://postgres:postgres@localhost:5434/trento_rag?sslmode=disable

# MCP Server Configuration
MCP_URL=http://localhost:5000
MCP_TOKEN=your-trento-pat-token-here

# Server Configuration
AGUI_ADDR=:8081

# Optional: Custom system prompt
# SYSTEM_PROMPT="Custom prompt here"
